# Public app URL used for share links and auth callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional comma-separated dev preview origins for local tunnels or private DNS.
NEXT_ALLOWED_DEV_ORIGINS=

# Candidate auth provider. Exact Privy setup will be stress-tested later.
NEXT_PUBLIC_PRIVY_APP_ID=

# Local Postgres in development; Neon-compatible connection string when hosted.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/titan_racers

# S3-compatible object storage for uploaded kart models and generated assets.
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
