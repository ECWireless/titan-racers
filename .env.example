# Public app URL used for share links and auth callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional comma-separated dev preview origins for local tunnels or private DNS.
NEXT_ALLOWED_DEV_ORIGINS=

# Better Auth server URL, signing secret, and Google OAuth credentials.
BETTER_AUTH_URL=http://localhost:3000
# Generate a cryptographically random value of at least 32 characters.
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local Postgres in development; Neon-compatible connection string when hosted.
DATABASE_URL=postgres://postgres:postgres@localhost:55432/titan_racers

# Direct, non-pooled connection used only when applying hosted migrations.
# Local development may omit this and use DATABASE_URL for both purposes.
DATABASE_MIGRATION_URL=

# S3-compatible object storage for uploaded kart models and generated assets.
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
